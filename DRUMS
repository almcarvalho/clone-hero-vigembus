// DRUMS - ESP32 COM BOTÕES
#include <WiFi.h>
#include <WiFiManager.h>
#include <WiFiUdp.h>

const char* NOME_PORTAL = "DRUMS";
const int LED_AZUL = 2;

WiFiManager wm;
WiFiUDP udp;

const uint16_t PORTA_UDP = 5001;
IPAddress broadcastIP(255, 255, 255, 255);

bool portalAberto = false;

// BOTÕES
const int BTN_RED    = 13;
const int BTN_YELLOW = 12;
const int BTN_BLUE   = 14;
const int BTN_GREEN  = 27;
const int BTN_ORANGE = 26;
const int BTN_KICK   = 25;
const int BTN_START  = 33;

bool lastRed = HIGH;
bool lastYellow = HIGH;
bool lastBlue = HIGH;
bool lastGreen = HIGH;
bool lastOrange = HIGH;
bool lastKick = HIGH;
bool lastStart = HIGH;

const unsigned long TEMPO_DEBOUNCE = 25;
const unsigned long TEMPO_REPETICAO = 80;

void configModeCallback(WiFiManager*) {
  portalAberto = true;
}

void enviar(const char* b, const char* a) {
  udp.beginPacket(broadcastIP, PORTA_UDP);
  udp.print(b);
  udp.print(":");
  udp.print(a);
  udp.endPacket();
}

void controlarLed() {
  static bool e = false;
  static unsigned long t = 0;

  if (WiFi.status() == WL_CONNECTED) {
    portalAberto = false;
    digitalWrite(LED_AZUL, HIGH);
  }
  else if (portalAberto) {
    if (millis() - t > 300) {
      t = millis();
      e = !e;
      digitalWrite(LED_AZUL, e);
    }
  }
  else {
    digitalWrite(LED_AZUL, LOW);
  }
}

void verificarBotao(int pino, bool &ultimoEstado, const char* nome, bool pulsoRapido)
{
    static unsigned long ultimoTempoMudanca[40] = {0};
    static unsigned long ultimoDisparo[40] = {0};

    bool leitura = digitalRead(pino);

    if (leitura != ultimoEstado) {

        if (millis() - ultimoTempoMudanca[pino] < TEMPO_DEBOUNCE)
            return;

        ultimoTempoMudanca[pino] = millis();
        ultimoEstado = leitura;

        if (leitura == LOW) {

            if (millis() - ultimoDisparo[pino] < TEMPO_REPETICAO)
                return;

            ultimoDisparo[pino] = millis();

            enviar(nome, "DOWN");

            if (pulsoRapido)
                enviar(nome, "UP");

        } else {

            if (!pulsoRapido)
                enviar(nome, "UP");

        }
    }
}

void setup() {
  Serial.begin(115200);

  pinMode(LED_AZUL, OUTPUT);

  pinMode(BTN_RED, INPUT_PULLUP);
  pinMode(BTN_YELLOW, INPUT_PULLUP);
  pinMode(BTN_BLUE, INPUT_PULLUP);
  pinMode(BTN_GREEN, INPUT_PULLUP);
  pinMode(BTN_ORANGE, INPUT_PULLUP);
  pinMode(BTN_KICK, INPUT_PULLUP);
  pinMode(BTN_START, INPUT_PULLUP);

  wm.setAPCallback(configModeCallback);
  wm.setConfigPortalBlocking(false);
  wm.autoConnect(NOME_PORTAL);

  udp.begin(PORTA_UDP);
}

void loop() {
  wm.process();
  controlarLed();

  verificarBotao(BTN_RED, lastRed, "DRUM_RED", true);
  verificarBotao(BTN_YELLOW, lastYellow, "DRUM_YELLOW", true);
  verificarBotao(BTN_BLUE, lastBlue, "DRUM_BLUE", true);
  verificarBotao(BTN_GREEN, lastGreen, "DRUM_GREEN", true);
  verificarBotao(BTN_ORANGE, lastOrange, "DRUM_ORANGE", true);

  verificarBotao(BTN_KICK, lastKick, "KICK", false);
  verificarBotao(BTN_START, lastStart, "START", false);
}
